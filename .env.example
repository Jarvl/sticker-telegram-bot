# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# Postgres database used for group-managed sticker packs
DATABASE_URL=postgresql+psycopg://sticker_bot:sticker_bot@postgres:5432/sticker_bot

# Running mode (either "webhook" or "polling")
MODE="polling"

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Optional: Webhook URL (if using webhooks instead of polling)
# WEBHOOK_URL=https://your-domain.com/webhook
